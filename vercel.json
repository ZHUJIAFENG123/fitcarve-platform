{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://your-backend-url.onrender.com/api/:path*" },
    { "source": "/uploads/:path*", "destination": "https://your-backend-url.onrender.com/uploads/:path*" },
    { "source": "/exercise-gifs/:path*", "destination": "https://your-backend-url.onrender.com/exercise-gifs/:path*" },
    { "source": "/news-images/:path*", "destination": "https://your-backend-url.onrender.com/news-images/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
