# ===== 生产环境配置 =====
NODE_ENV=production
PORT=5000

# ===== 数据库配置（必填）=====
# 如果你在同一台服务器安装 MySQL，填 localhost
# 如果使用腾讯云云数据库 MySQL，填实例内网地址
MYSQL_HOST=localhost
MYSQL_USER=fitness_user
MYSQL_PASSWORD=在这里填写你的强密码
MYSQL_DATABASE=community_db

# ===== JWT 密钥（必填，必须修改！）=====
# 生产环境务必使用随机生成的强密码字符串（建议 64 位以上）
# 在线生成工具：https://1password.com/password-generator/
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_STRING_AT_LEAST_64_CHARS
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ===== 邮件服务（可选，不填则跳过邮件功能）=====
EMAIL_SERVICE=gmail
EMAIL_USER=
EMAIL_PASS=

# ===== AI 配置（可选，用于 AI 功能）=====
# 注册获取: https://platform.deepseek.com
AI_API_KEY=
AI_API_URL=https://api.deepseek.com/v1/chat/completions
AI_MODEL=deepseek-chat
