{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "command": "npm ci && npm run build && cd backend && npm ci"
  },
  "deploy": {
    "command": "cd backend && NODE_ENV=production node server.js",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE"
  }
}
